{
  "name": "dynamic-ui-canvas",
  "version": "0.1.0",
  "description": "Canvas API Server for Jane's Dynamic UI system — serves interactive UI components defined by JSON descriptors",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@types/pg": "^8.16.0",
    "hono": "^4.0.0",
    "pg": "^8.18.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  }
}
