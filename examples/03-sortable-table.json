              { "name": "Frank Brown", "email": "frank@company.com", "department": "Engineering", "role": "Junior Engineer", "startDate": "2024-01-15", "salary": 85000, "status": "Active" },
              { "name": "Grace Kim", "email": "grace@company.com", "department": "HR", "role": "HR Director", "startDate": "2017-05-20", "salary": 155000, "status": "On Leave" },
              { "name": "Henry Chen", "email": "henry@company.com", "department": "Engineering", "role": "DevOps Engineer", "startDate": "2021-09-01", "salary": 140000, "status": "Remote" },
